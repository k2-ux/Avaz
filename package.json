    "build-debug-apk": "cd android && ./gradlew clean && cd .. && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ./gradlewew assembleDebug && cd ..",
    "build-release-apk": "cd android &&  ./gradlew clean && ./gradlew assembleRelease && cd ..",
    "build-aab": "cd android && ./gradlew clean && gradlew.bat bundleRelease && cd..",
    "clean": "cd android && ./gradlew clean && cd ..",
    "reset-cache": "react-native start --reset-cache"
  },
